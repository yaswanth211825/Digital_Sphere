<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F5F5">

    <TextView
        android:text="👨‍🏫 Professor Panel"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/tv_session_status"
        android:text="Session: Inactive"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Session name input -->
    <EditText
        android:id="@+id/et_session_name"
        android:hint="Session name (e.g. CS101)"
        android:textSize="16sp"
        android:inputType="text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:padding="12dp"
        android:background="@android:color/white"/>

    <!-- Timer input row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <EditText
            android:id="@+id/et_duration"
            android:hint="Duration (mins)"
            android:textSize="15sp"
            android:inputType="number"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="12dp"
            android:background="@android:color/white"/>

        <TextView
            android:id="@+id/tv_countdown"
            android:text=""
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#E74C3C"
            android:gravity="center"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="8dp"/>
    </LinearLayout>

    <TextView
        android:text="Tip: 5 minutes is the recommended session duration"
        android:textSize="12sp"
        android:textColor="#AAAAAA"
        android:layout_marginBottom="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btn_start_session"
            android:text="▶ Start"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#2ECC71"/>

        <Button
            android:id="@+id/btn_stop_session"
            android:text="⏹ Stop"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:backgroundTint="#E74C3C"
            android:enabled="false"/>
    </LinearLayout>

    <!-- Attendance section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:text="Attendance"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/tv_count"
            android:text="0 present"
            android:textSize="14sp"
            android:textColor="#2ECC71"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <ListView
        android:id="@+id/lv_attendance"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@android:color/white"
        android:dividerHeight="1dp"
        android:padding="4dp"/>

    <Button
        android:id="@+id/btn_export"
        android:text="📤 Export CSV"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#3498DB"/>

</LinearLayout>
