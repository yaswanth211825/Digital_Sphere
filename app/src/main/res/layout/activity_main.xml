<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#F5F5F5">

    <TextView
        android:text="🌐 Digital Sphere"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="12dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:text="Smart Attendance System"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="56dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/btn_professor"
        android:text="👨‍🏫  I am a Professor"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#1A1A2E"/>

    <Button
        android:id="@+id/btn_student"
        android:text="🎓  I am a Student"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="#16213E"/>

</LinearLayout>